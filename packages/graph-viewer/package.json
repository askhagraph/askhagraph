{
  "name": "@askhagraph/graph-viewer",
  "version": "0.3.2",
  "private": true,
  "description": "Interactive Cytoscape.js graph viewer for AskhaGraph",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc --build && npm run bundle",
    "bundle": "esbuild src/webview-entry.ts --bundle --format=iife --global-name=AskhaGraph --outfile=dist/graph-viewer.bundle.js --platform=browser --target=es2022",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "cytoscape": "^3.33.1",
    "cytoscape-elk": "^2.3.0",
    "elkjs": "^0.10.0"
  },
  "devDependencies": {
    "@types/cytoscape": "^3.21.8",
    "esbuild": "^0.24.0"
  }
}
